   ],
   "source": [
    "c = 0\n",
    "def show(name,n):\n",
    "        global c\n",
    "        if  c == n:\n",
    "            return \n",
    "        print(name) \n",
    "        c+=1\n",
    "        show(\"Harsh\",n)\n",
    "show(\"Harsh\",5)"
   ]
